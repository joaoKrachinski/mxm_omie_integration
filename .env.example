# ─────────────────────────────────────────
# Comuns a todos os serviços
# ─────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
SERVICE_TIMEOUT_SECONDS=30

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=ftd_integracoes
MONGODB_COLLECTION_PAYMENT_INTEGRATIONS=payment_integrations

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_ALERT_CHANNEL=#alertas-integracao

# GCP
GCP_PROJECT_ID=ftd-data-lake
GCP_REGION=us-east1

# ─────────────────────────────────────────
# mxm-omie-sync-service (porta 3001)
# ─────────────────────────────────────────
PORT_SYNC=3001
MXM_BASE_URL=https://api.mxm.com.br
MXM_AUTH_TOKEN=your_mxm_auth_token
OMIE_BASE_URL=https://app.omie.com.br
OMIE_APP_KEY=your_omie_app_key
OMIE_APP_SECRET=your_omie_app_secret
SYNC_WINDOW_HOURS=26

# ─────────────────────────────────────────
# jira-payment-orchestrator-service (porta 3002)
# ─────────────────────────────────────────
PORT_JIRA=3002
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_TAB_NAME=Sheet1
GOOGLE_SHEETS_RANGE=A1:Z1000

# ─────────────────────────────────────────
# omie-payment-settlement-service (porta 3003)
# ─────────────────────────────────────────
PORT_SETTLEMENT=3003
OMIE_WEBHOOK_TOKEN=your_webhook_token_secret
RECONCILIATION_SCHEDULE=0 23 * * *
