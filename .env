NODE_ENV=development
LOG_LEVEL=info
SERVICE_TIMEOUT_SECONDS=30

MONGODB_DATABASE=ftd_integracoes
MONGODB_COLLECTION_PAYMENT_INTEGRATIONS=payment_integrations

SLACK_BOT_TOKEN=fake-token
SLACK_ALERT_CHANNEL=#alertas-integracao

GCP_PROJECT_ID=ftd-data-lake
GCP_REGION=us-east1

PORT_SYNC=3001
MXM_BASE_URL=http://fake-mxm
MXM_AUTH_TOKEN=fake-mxm-token
OMIE_BASE_URL=http://fake-omie
OMIE_APP_KEY=fake-key
OMIE_APP_SECRET=fake-secret
SYNC_WINDOW_HOURS=26

PORT_JIRA=3002
JIRA_BASE_URL=http://fake-jira
JIRA_EMAIL=fake@fake.com
JIRA_API_TOKEN=fake-jira-token
GOOGLE_SHEETS_SPREADSHEET_ID=fake-sheet-id
GOOGLE_SHEETS_TAB_NAME=Sheet1
GOOGLE_SHEETS_RANGE=A1:Z1000

PORT_SETTLEMENT=3003
OMIE_WEBHOOK_TOKEN=fake-webhook-token
RECONCILIATION_SCHEDULE=0 23 * * *
