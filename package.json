{
  "name": "integracao-mxm-omie-simplificado",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev:sync": "tsx services/mxm-omie-sync-service/src/server.ts",
    "dev:jira": "tsx services/jira-payment-orchestrator-service/src/server.ts",
    "dev:settlement": "tsx services/omie-payment-settlement-service/src/server.ts",
    "local:sync": "tsx dev-local.ts sync",
    "local:jira": "tsx dev-local.ts jira",
    "local:settlement": "tsx dev-local.ts settlement",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"{shared,adapters,services,tests}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "fastify": "^5.8.5",
    "googleapis": "^173.0.0",
    "mongodb": "^6.10.0",
    "mongoose": "^9.7.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.18.0",
    "mongodb-memory-server": "^11.2.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
